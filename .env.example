# =========================
# App
# =========================
APP_NAME=price-audit-copilot
APP_ENV=dev
DEBUG=true
API_PREFIX=/api

# =========================
# Database
# 本地运行：
# DATABASE_URL=mysql+pymysql://root:123456@127.0.0.1:3306/price_audit_db?charset=utf8mb4
#
# Docker Compose 运行：
# DATABASE_URL=mysql+pymysql://root:123456@mysql:3306/price_audit_db?charset=utf8mb4
# =========================
DATABASE_URL=mysql+pymysql://root:123456@127.0.0.1:3306/price_audit_db?charset=utf8mb4

# =========================
# Log
# =========================
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE_NAME=app.log

# =========================
# Trace
# =========================
TRACE_HEADER_NAME=X-Trace-Id

# =========================
# LLM / RAG
# 本地运行：
# OLLAMA_BASE_URL=http://127.0.0.1:11434
#
# Docker 容器访问宿主机 Ollama：
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# =========================
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
RETRIEVAL_TOP_K=5

# =========================
# Feature Flags
# =========================
ASK_LOG_ENABLED=true
MODEL_CALL_LOG_ENABLED=true
REVIEW_LOG_ENABLED=true